# ============================================================
# IGNORAR CARPETA DE COMPILACIÓN DE MAVEN
# ============================================================

# /target/
# Esta carpeta es generada automáticamente por Maven al compilar el proyecto.
# Contiene:
# - Archivos compilados (.class)
# - El archivo .jar final
# - Recursos temporales de build
#
# NO debe subirse al repositorio porque:
# - Se regenera en cada compilación
# - Aumenta innecesariamente el tamaño del proyecto
# - Puede generar conflictos entre entornos
/target/


# ============================================================
# IGNORAR ARCHIVOS DE LOG
# ============================================================

# *.log
# Ignora todos los archivos de logs generados por la aplicación.
# Estos archivos:
# - No son necesarios en control de versiones
# - Pueden contener información sensible
# - Generan ruido en el repositorio
*.log


# ============================================================
# IGNORAR CONFIGURACIONES DE ENTORNO LOCAL (CLAVE 🔐)
# ============================================================

# application-dev.properties
# Archivo con configuraciones locales sensibles como:
# - Credenciales de base de datos
# - Claves JWT
# - Usuario administrador
#
# ESTE ARCHIVO NO DEBE SUBIRSE A GITHUB
# Cada desarrollador debe tener su propia versión local.
src/main/resources/application-dev.properties


# ============================================================
# IGNORAR CONFIGURACIONES DE IDE
# ============================================================

# Visual Studio Code
.vscode/

# IntelliJ IDEA
.idea/


# ============================================================
# IGNORAR ARCHIVOS DEL SISTEMA OPERATIVO
# ============================================================

# macOS
.DS_Store

# Windows
Thumbs.db


# ============================================================
# OTROS ARCHIVOS TEMPORALES
# ============================================================

# Logs generados manualmente por Maven u otros procesos
mvn-log.txt

